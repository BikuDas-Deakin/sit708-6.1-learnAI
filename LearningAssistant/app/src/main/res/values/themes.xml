<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LearningAssistant" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:statusBarColor">@color/background_blue</item>
        <item name="android:windowBackground">@color/background_blue</item>
    </style>

    <style name="Theme.LearningAssistant.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background_blue</item>
        <item name="android:statusBarColor">@color/background_blue</item>
    </style>

    <style name="Theme.LearningAssistant.White" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/primary</item>
    </style>

    <style name="TextInputWhite" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/white</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="hintTextColor">@color/white_70</item>
        <item name="android:textColorHint">@color/white_70</item>
        <item name="boxBackgroundColor">#22FFFFFF</item>
        <item name="shapeAppearanceOverlay">@style/RoundedBox</item>
    </style>

    <style name="RoundedBox">
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="ChipStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textColor">@color/white</item>
        <item name="chipBackgroundColor">@color/chip_unselected</item>
        <item name="chipStrokeColor">@color/white</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <style name="ButtonPrimary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/accent_green</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="cornerRadius">28dp</item>
    </style>
</resources>
